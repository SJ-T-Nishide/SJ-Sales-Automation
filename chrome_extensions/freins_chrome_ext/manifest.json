{
  "manifest_version": 3,
  "name": "ふれんず物件抽出",
  "version": "1.0",
  "description": "ふれんず検索結果から物件データを抽出し、TSV形式でスプレッドシートに貼り付けられます。",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "clipboardWrite",
    "downloads"
  ],
  "host_permissions": [
    "https://www.f-takken.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.f-takken.com/freins/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "ふれんず物件抽出",
    "default_icon": {
      "48": "icon48.png"
    }
  },
  "icons": {
    "48": "icon48.png"
  }
}
