# ─── GAS Web App ─────────────────────────────────────────────
# デプロイ後に取得したURLを設定してください
GAS_QUEUE_URL=https://script.google.com/macros/s/XXXXX/exec

# Script Properties の PLAYWRIGHT_TOKEN と同じ値を設定してください
GAS_TOKEN=your_secret_token_here

# ─── ファイルパス ─────────────────────────────────────────────
# ダウンロード一時フォルダ（存在しない場合は自動作成）
DOWNLOAD_TEMP_DIR=C:\Users\tnish\Downloads\airdna_temp

# GAS の csv_import_folder_id に対応する Google Drive のローカルパス
# Google Drive for Desktop がマウントしているフォルダを指定
DRIVE_IMPORT_FOLDER=G:\マイドライブ\AirDNA_Import

# ─── 実行設定 ─────────────────────────────────────────────────
# 1回の実行でExportする件数（テスト時は1、本番は10）
QUEUE_LIMIT=1

# ヘッドレスモード
# false = ブラウザ画面を表示（推奨: テスト時・初回ログイン時）
# true  = バックグラウンド実行（タスクスケジューラ自動実行時）
# 注意: npm run login（初回ログイン）は必ず HEADLESS=false で実行してください
HEADLESS=false
